{
  "manifest_version": 3,
  "name": "ChatGPT Quiz Mode",
  "description": "Detects multiple-choice and SATA answers in ChatGPT outputs, hides answer keys, and adds answer controls.",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://extensionpay.com/*"
      ],
      "js": [
        "ExtPay.js"
      ],
      "run_at": "document_start"
    }
  ]
}
